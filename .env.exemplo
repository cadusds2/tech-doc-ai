# Aplicação
NOME_APP=Tech Doc AI
VERSAO_APP=0.1.0
AMBIENTE=desenvolvimento
HOST_API=0.0.0.0
PORTA_API=8000
PREFIXO_API=

# Logging
NIVEL_LOG=INFO
FORMATO_LOG=%(asctime)s | %(levelname)s | %(name)s | %(identificador_requisicao)s | %(message)s

# Banco de dados e pgvector
URL_BANCO=postgresql+psycopg://postgres:postgres@localhost:5432/tech_doc_ai
HABILITAR_PGVECTOR=true

# Embeddings e indexação
MODELO_EMBEDDINGS=sentence-transformers/all-MiniLM-L6-v2
DIMENSAO_EMBEDDINGS=384
TAMANHO_LOTE_INDEXACAO=100

# Chunking
TAMANHO_TRECHO=800
SOBREPOSICAO_TRECHO=120
TAMANHO_MAXIMO_TOKENS_TRECHO=256
SOBREPOSICAO_TOKENS_TRECHO=40
USAR_CHUNKING_POR_TOKENS=false

# Consulta RAG
LIMITE_BUSCA_PADRAO=4
PESO_BUSCA_VETORIAL=0.7
PESO_BUSCA_LEXICAL=0.3
HABILITAR_RERANQUEAMENTO=true

# Upload
TAMANHO_MAXIMO_UPLOAD_BYTES=10485760

# Modelo de linguagem
PROVEDOR_MODELO_LINGUAGEM=heuristico
MODELO_LINGUAGEM=gpt-4.1-mini
CHAVE_API_MODELO_LINGUAGEM=
TEMPERATURA_MODELO_LINGUAGEM=0.2
TEMPO_LIMITE_MODELO_LINGUAGEM=30.0
URL_API_MODELO_LINGUAGEM=
